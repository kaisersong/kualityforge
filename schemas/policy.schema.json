{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kualityforge.local/schemas/policy.schema.json",
  "title": "KualityForge Policy",
  "type": "object",
  "properties": {
    "profile": { "type": "string" },
    "minReviewers": { "type": "integer", "minimum": 1 },
    "requireHumanDecision": { "type": "boolean" },
    "requireRequiredChecks": { "type": "boolean" },
    "requireIndependentVerifier": { "type": "boolean" },
    "context": {
      "type": "object",
      "properties": {
        "projectContextRequired": { "type": "boolean" },
        "qualityPrinciplesRequired": { "type": "boolean" },
        "requiredReviewerContextAck": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requireReviewerContextProvenance": { "type": "boolean" },
        "requiredInstructionFiles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "optionalInstructionFiles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "docsRoots": {
          "type": "array",
          "items": { "type": "string" }
        },
        "designEntrypoints": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "qualityPrinciples": {
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "mustPrincipleExceptionPolicy": { "type": "string" }
      }
    },
    "review": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["required_all", "quorum"] },
        "requiredReviewers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "advisoryReviewers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "quorumMembers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "quorumMin": { "type": "integer", "minimum": 1 }
      },
      "required": ["mode"]
    },
    "artifactRoot": { "type": "string" }
  }
}

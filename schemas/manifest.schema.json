{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kualityforge.local/schemas/manifest.schema.json",
  "title": "KualityForge Manifest",
  "type": "object",
  "required": ["runId", "status", "reviewers", "findings", "requiredChecks"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "runId": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string" },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "incomplete",
        "approved_for_fix",
        "fixed",
        "partially_fixed",
        "wont_fix",
        "risk_accepted",
        "verified",
        "verification_failed",
        "test_blocked",
        "failed",
        "invalid_artifact",
        "cancelled"
      ]
    },
    "profile": { "type": "string" },
    "reviewers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["runnerId", "artifact"],
        "properties": {
          "runnerId": { "type": "string" },
          "status": { "type": "string" },
          "artifact": { "type": "string" },
          "role": { "type": "string", "enum": ["required", "advisory"] },
          "quorumMember": { "type": "boolean" },
          "contextRead": {
            "type": "object",
            "additionalProperties": { "type": "boolean" }
          },
          "contextConfidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "contextGaps": {
            "type": "array",
            "items": { "type": "string" }
          },
          "contextProvenance": {
            "type": "object",
            "properties": {
              "contextManifestHash": { "type": "string" },
              "promptContextHash": { "type": "string" }
            }
          },
          "principleAlignment": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    },
    "context": {
      "type": "object",
      "properties": {
        "contextManifest": { "$ref": "#/$defs/artifactReference" },
        "qualityPrinciples": { "$ref": "#/$defs/artifactReference" },
        "projectContext": { "$ref": "#/$defs/artifactReference" },
        "projectBrief": { "$ref": "#/$defs/artifactReference" },
        "docsIndex": { "$ref": "#/$defs/artifactReference" },
        "changeset": { "$ref": "#/$defs/artifactReference" },
        "structureScan": { "anyOf": [{ "$ref": "#/$defs/artifactReference" }, { "type": "null" }] }
      }
    },
    "humanDecision": {
      "type": "object",
      "properties": {
        "artifact": { "type": "string" },
        "owner": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "fixer": {
      "type": "object",
      "properties": {
        "runnerId": { "type": "string" },
        "artifact": { "type": "string" }
      }
    },
    "synthesis": {
      "type": "object",
      "properties": {
        "artifact": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "verification": {
      "type": "object",
      "properties": {
        "runnerId": { "type": "string" },
        "status": { "type": "string" },
        "artifact": { "type": "string" },
        "verdicts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["findingId", "status"],
            "properties": {
              "findingId": { "type": "string" },
              "status": { "type": "string", "enum": ["confirmed", "dismissed", "cannot_verify"] },
              "notes": { "type": "string" }
            }
          }
        },
        "verdictCount": { "type": "integer", "minimum": 0 },
        "confirmedCount": { "type": "integer", "minimum": 0 },
        "dismissedCount": { "type": "integer", "minimum": 0 },
        "cannotVerifyCount": { "type": "integer", "minimum": 0 }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "principleId": { "type": ["string", "null"] },
          "priority": { "type": ["string", "null"] },
          "role": { "type": "string", "enum": ["required", "advisory"] },
          "title": { "type": "string" },
          "status": { "type": "string" },
          "severity": { "type": "string" },
          "duplicateKey": { "type": "string" },
          "sourceRunnerId": { "type": "string" },
          "sourceRunnerIds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "reviewerCount": { "type": "integer", "minimum": 0 },
          "dismissedBy": { "type": "string" },
          "verificationNote": { "type": "string" }
        }
      }
    },
    "requiredChecks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string" },
          "command": { "type": "string" },
          "log": { "type": "string" }
        }
      }
    },
    "reviewPolicy": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["required_all", "quorum"] },
        "requiredReviewers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "advisoryReviewers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "quorumMembers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "quorumMin": { "type": "integer", "minimum": 1 }
      }
    },
    "reviewOutcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["runnerId", "status"],
        "properties": {
          "runnerId": { "type": "string" },
          "status": { "type": "string", "enum": ["succeeded", "failed", "skipped"] },
          "absenceReason": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "artifactReference": {
      "type": "object",
      "required": ["artifact", "sha256"],
      "properties": {
        "artifact": { "type": "string" },
        "sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      }
    }
  }
}

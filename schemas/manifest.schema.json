{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kualityfore.local/schemas/manifest.schema.json",
  "title": "KualityFore Manifest",
  "type": "object",
  "required": ["runId", "status", "reviewers", "findings", "requiredChecks"],
  "properties": {
    "runId": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "incomplete",
        "approved_for_fix",
        "fixed",
        "partially_fixed",
        "wont_fix",
        "risk_accepted",
        "verified",
        "verification_failed",
        "test_blocked",
        "failed",
        "invalid_artifact",
        "cancelled"
      ]
    },
    "profile": { "type": "string" },
    "reviewers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["runnerId", "artifact"],
        "properties": {
          "runnerId": { "type": "string" },
          "artifact": { "type": "string" }
        }
      }
    },
    "humanDecision": {
      "type": "object",
      "properties": {
        "artifact": { "type": "string" },
        "owner": { "type": "string" }
      }
    },
    "fixer": {
      "type": "object",
      "properties": {
        "runnerId": { "type": "string" },
        "artifact": { "type": "string" }
      }
    },
    "verification": {
      "type": "object",
      "properties": {
        "runnerId": { "type": "string" },
        "status": { "type": "string" },
        "artifact": { "type": "string" }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string" },
          "status": { "type": "string" },
          "severity": { "type": "string" }
        }
      }
    },
    "requiredChecks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string" },
          "command": { "type": "string" },
          "log": { "type": "string" }
        }
      }
    }
  }
}
